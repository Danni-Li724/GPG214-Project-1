# Force consistent line endings for text files (Unity likes LF fine on all OS)
* text=auto eol=lf

# Unity / text assets
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.compute   text eol=lf
*.uxml      text eol=lf
*.uss       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.meta      text eol=lf
*.asset     text eol=lf
* text=auto eol=lf

# Common binaries (never touch line endings)
*.png  binary
*.jpg  binary
*.jpeg binary
*.wav  binary
*.mp3  binary
*.fbx  binary
*.psd  binary
*.ttf  binary
*.otf  binary

